# Katana / Zenith – copy to .env and fill in values.
# Full list and details: see ENV.md

# =============================================================================
# Supabase (required for Sign in with Microsoft)
# =============================================================================
# Get these from: https://supabase.com/dashboard → your project → Settings → API
# See SUPABASE_AUTH_SETUP.md for full Microsoft login setup.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# =============================================================================
# EmailJS (for demo request emails and project invite emails)
# =============================================================================
# Get these from https://www.emailjs.com/ — see EMAILJS_SETUP.md
# For project invites (Share tab), use a service connected to:
#   katanatechnologysystems@gmail.com
# so invitations are sent from that address.

VITE_EMAILJS_SERVICE_ID=service_lidcm3g
VITE_EMAILJS_TEMPLATE_ID=template_a3bis2i
VITE_EMAILJS_PUBLIC_KEY=mB61qPklsPh1nAtns

# Optional: separate EmailJS service/template for project invitations (Share tab).
# If set, invitations are sent using this service (connect it to katanatechnologysystems@gmail.com).
# If not set, the service/template above are used.
# VITE_EMAILJS_INVITE_SERVICE_ID=your_invite_service_id_here
# VITE_EMAILJS_INVITE_TEMPLATE_ID=your_invite_template_id_here

# =============================================================================
# Know Your Investor (KYI) – optional embedded module
# =============================================================================
# URL of the KYI Flask app to embed in the KYI module (e.g. http://localhost:5000).
# If unset, the KYI page shows setup instructions.
# VITE_KYI_APP_URL=http://localhost:5000

# Path to KYI CSV data for import (fec_donors.csv, sec_13f.csv, etc.).
# Default: zenith/data/kyi (no need to set unless using another folder).
# KYI_DATA_PATH=./data/kyi

# Client ID used as the platform lead pool (all imports go here; every company sees this pool filtered by their geo). Default: 1.
# KYI_PLATFORM_CLIENT_ID=1
